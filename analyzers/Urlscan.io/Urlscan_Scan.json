{
  "name": "Urlscan.io_Scan",
  "author": "ninoseki; Kyle Parrish (@arnydo); Fabien Bloume, StrangeBee",
  "license": "MIT",
  "url": "https://github.com/arnydo/Cortex-Analyzers",
  "version": "0.2.0",
  "description": "Scan URLs on urlscan.io",
  "dataTypeList": ["url", "domain", "fqdn"],
  "command": "Urlscan.io/urlscan_analyzer.py",
  "baseConfig": "Urlscan.io",
  "config": {
    "service":"scan"
  },
  "configurationItems": [
    {
      "name": "key",
      "description": "API key for Urlscan.io",
      "type": "string",
      "multi": false,
      "required": true
    },
    {
      "name": "visibility",
      "description": "Visibility of the scan result on Urlscan.io (public, unlisted or private)",
      "type": "string",
      "multi": false,
      "required": false,
      "defaultValue": "public"
    }
  ],
  "registration_required": true,
  "subscription_required": false,
  "free_subscription": true,
  "service_homepage": "https://urlscan.io/"
}
